# Copie ce fichier en .env et remplis les valeurs

# Anthropic (obligatoire)
ANTHROPIC_API_KEY=sk-ant-...

# AWS S3 (optionnel en dev — les audios seront stockés localement)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=meetingmind-audio

# HuggingFace (pour pyannote diarisation)
# Accepte les conditions sur https://hf.co/pyannote/speaker-diarization-3.1
HF_TOKEN=hf_...

# PostgreSQL — ne pas changer si tu utilises Docker Compose
DATABASE_URL=postgresql+asyncpg://meetingmind:secret@localhost:5432/meetingmind

# Whisper model : tiny (rapide) | base | small | medium | large (précis)
WHISPER_MODEL=base
